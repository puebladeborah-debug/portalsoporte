rules_version = '2';

// Reglas de seguridad para el Portal de Soporte — Club Sinergético.
// Solo el equipo con sesión real de Firebase (creada en Authentication)
// puede leer o escribir datos. Nadie sin sesión puede acceder a nada.
service cloud.firestore {
  match /databases/{database}/documents {

    // Bloquea todo por defecto; cada colección se habilita explícitamente abajo.
    match /{document=**} {
      allow read, write: if false;
    }

    // Directorio público: solo username → correo. Necesario para que el
    // login pueda ubicar el correo de alguien ANTES de tener sesión
    // (Firebase pide correo, no username, para autenticar). No expone
    // contraseñas, permisos ni ningún otro dato del equipo.
    match /directorio/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Cualquier persona del equipo autenticada puede leer y escribir
    // estas colecciones (chat, guardias, pagos, incidencias, reembolsos, etc.)
    match /equipo/{docId} {
      allow read, write: if request.auth != null;
    }
    match /guardias/{docId} {
      allow read, write: if request.auth != null;
    }
    match /guardia_patron/{docId} {
      allow read, write: if request.auth != null;
    }
    match /chat_conversaciones/{docId} {
      allow read, write: if request.auth != null;
    }
    match /chat_mensajes/{docId} {
      allow read, write: if request.auth != null;
    }
    match /incidencias/{docId} {
      allow read, write: if request.auth != null;
    }
    match /reembolsos/{docId} {
      allow read, write: if request.auth != null;
    }
    match /tareas_extra/{docId} {
      allow read, write: if request.auth != null;
    }
    match /asistencia/{docId} {
      allow read, write: if request.auth != null;
    }

    // Agenda personal (Pendientes, Notas, Llamadas): privada de verdad.
    // Ni siquiera el administrador puede leer o escribir lo de otra
    // persona — Firebase compara el dueño real de la sesión (su UID de
    // autenticación) contra el dueño guardado, sin excepción para nadie.
    match /notas_personales/{noteId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUid;
    }
    match /agenda_pendientes/{itemId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUid;
    }
    match /agenda_llamadas/{callId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUid;
    }
  }
}
