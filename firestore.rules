rules_version = '2';

// Reglas de seguridad para el Portal de Soporte — Club Sinergético.
// Solo el equipo con sesión real de Firebase (creada en Authentication)
// puede leer o escribir datos. Nadie sin sesión puede acceder a nada.
service cloud.firestore {
  match /databases/{database}/documents {

    // Bloquea todo por defecto; cada colección se habilita explícitamente abajo.
    match /{document=**} {
      allow read, write: if false;
    }

    // Cualquier persona del equipo autenticada puede leer y escribir
    // estas colecciones (chat, guardias, pagos, incidencias, reembolsos, etc.)
    match /equipo/{docId} {
      allow read, write: if request.auth != null;
    }
    match /guardias/{docId} {
      allow read, write: if request.auth != null;
    }
    match /guardia_patron/{docId} {
      allow read, write: if request.auth != null;
    }
    match /chat_conversaciones/{docId} {
      allow read, write: if request.auth != null;
    }
    match /chat_mensajes/{docId} {
      allow read, write: if request.auth != null;
    }
    match /incidencias/{docId} {
      allow read, write: if request.auth != null;
    }
    match /reembolsos/{docId} {
      allow read, write: if request.auth != null;
    }
    match /tareas_extra/{docId} {
      allow read, write: if request.auth != null;
    }
    match /asistencia/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
